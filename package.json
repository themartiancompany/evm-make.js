{ "name": "evm-make",
  "version":
    "0.0.2",
  "description":
    "Make (build and install) tool for applications developed using LibEVM and the EVM toolchain.",
  "funding": {
    "type":
      "patreon",
    "url":
      "https://patreon.com/tallero"
  },
  "man": [
    "./man/ur.1"
  ],
  "files": [
    "AUTHORS.rst",
    "COPYING",
    "README.md",
    "dist",
    "evm-make",
    "libevm-make",
    "libevm-make.webpack.config.js",
    "fs-worker.webpack.config.js",
    "package.json",
    "serve.json",
    "webpack.config.js"
  ],
  "keywords": [
    "ur",
    "themartiancompany",
    "dogeos",
    "ethereum",
    "evmfs",
    "libevm",
    "evm-toolchain"
  ],
  "homepage":
    "https://github.com/themartiancompany/evm-make",
  "bugs": {
    "url":
      "https://github.com/themartiancompany/evm-make.js/issues"
  },
  "repository": {
    "type":
      "git",
    "url":
      "git+https://github.com/themartiancompany/evm-make.js.git"
  },
  "license":
    "AGPL-3.0-or-later",
  "author": {
    "name":
      "Pellegrino Prevete",
    "email":
      "pellegrinoprevete@gmail.com",
    "url":
      "https://github.com/tallero"
  },
  "devDependencies": {
    "crash-js-webpack":
      "^0.0.10",
    "flatted":
      "^3.2.9",
    "eslint":
      "^10.0.3",
    "globals":
      "^17.3.0",
    "@eslint/js":
      "^10.0.1",
    "safely-serve":
      "^0.0.9",
    "webpack":
      "^5.102.1",
    "webpack-cli":
      "^6.0.1"
  },
  "dependencies": {
    "crash-js":
      "^0.1.111",
    "solidity-compiler.js":
      "^0.0.1",
    "yargs":
      "18.0.0"
  },
  "optionalDependencies": {
  },
  "type":
    "commonjs",
  "main":
    "libevm-make",
  "bin":
    { 
      "evm-make":
        "evm-make",
      "evm-make.js":
        "evm-make"
    },
  "yargs": {
    "parse-numbers":
      false,
    "parse-positional-numbers":
      false
  },
  "scripts": {
    "build-bin":
      "npx webpack --mode 'production' --config 'webpack.config.cjs' --stats-error-details && mv 'evm-make.js' 'dist/ur'",
    "build-fs-worker":
      "npx webpack --mode 'production' --config 'fs-worker.webpack.config.cjs' --stats-error-details && cp 'fs-worker.js' 'dist/evm-make' && cp 'fs-worker.js' 'dist/libevm-make'",
    "build-lib":
      "npx webpack --mode 'production' --config 'libevm-make.webpack.config.cjs' --stats-error-details && mv 'libevm-make.js' 'dist/libevm-make'",
    "build":
      "npm run lint && npm run build-fs-worker && npm run build-lib && npm run build-bin",
    "lint":
      "npx eslint .",
    "publish-npm":
      "npm run build && npm publish --access public",
    "start":
      "npx safely-serve 'dist/evm-make'",
    "test":
      "echo \"Error: no test specified\" && exit 1"
  }
}
